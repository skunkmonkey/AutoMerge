<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AutoMerge.UI.Views.Dialogs.MergeInputDialog"
        Width="640" Height="360"
        Title="Open Merge Files"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="12">
    <TextBlock Text="Open Merge Files" FontSize="18" FontWeight="Bold" />
    <TextBlock Text="Select Local (ours), Remote (theirs), and Merged (output). Base is optional."
               TextWrapping="Wrap" />

    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Base (optional)" VerticalAlignment="Center" Margin="0,0,8,8" />
      <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BasePath}" Margin="0,0,8,8" />
      <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Click="OnBrowseBaseClicked" Margin="0,0,0,8" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Local (ours)" VerticalAlignment="Center" Margin="0,0,8,8" />
      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LocalPath}" Margin="0,0,8,8" />
      <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Click="OnBrowseLocalClicked" Margin="0,0,0,8" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Remote (theirs)" VerticalAlignment="Center" Margin="0,0,8,8" />
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RemotePath}" Margin="0,0,8,8" />
      <Button Grid.Row="2" Grid.Column="2" Content="Browse..." Click="OnBrowseRemoteClicked" Margin="0,0,0,8" />

      <TextBlock Grid.Row="3" Grid.Column="0" Text="Merged (output)" VerticalAlignment="Center" Margin="0,0,8,0" />
      <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MergedPath}" Margin="0,0,8,0" />
      <Button Grid.Row="3" Grid.Column="2" Content="Browse..." Click="OnBrowseMergedClicked" />
    </Grid>

    <TextBlock Text="{Binding ErrorMessage}" Foreground="OrangeRed" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Cancel" Click="OnCancelClicked" />
      <Button Content="Open" Click="OnOpenClicked" IsEnabled="{Binding CanConfirm}" />
    </StackPanel>
  </StackPanel>
</Window>
