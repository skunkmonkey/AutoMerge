<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AutoMerge.Core.Models;assembly=AutoMerge.Core"
        x:Class="AutoMerge.UI.Views.Dialogs.PreferencesDialog"
        Width="520" Height="420"
        Title="Preferences"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  
  <Border Background="{StaticResource SurfaceBrush}"
          CornerRadius="0"
          Margin="0">
    <Grid RowDefinitions="Auto,*,Auto">
      
      <!-- Header -->
      <Border Grid.Row="0"
              Background="{StaticResource SurfaceElevatedBrush}"
              Padding="24,20">
        <StackPanel Spacing="4">
          <TextBlock Text="⚙️ Preferences" 
                     FontSize="20" 
                     FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}" />
          <TextBlock Text="Configure AutoMerge behavior and appearance"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>
      
      <!-- Settings Content -->
      <ScrollViewer Grid.Row="1" Padding="24">
        <StackPanel Spacing="24">
          
          <!-- AI Settings Section -->
          <StackPanel Spacing="12">
            <TextBlock Text="AI BEHAVIOR"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Margin="0,0,0,4" />
            
            <Border Background="{StaticResource SurfaceElevatedBrush}"
                    CornerRadius="8"
                    Padding="16">
              <StackPanel Spacing="16">
                
                <!-- Default Bias -->
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Default resolution bias"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Which version the AI should favor when resolving conflicts"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                  </StackPanel>
                  <ComboBox Grid.Column="1"
                            Width="140"
                            ItemsSource="{Binding DefaultBiasOptions}"
                            SelectedItem="{Binding DefaultBias}" />
                </Grid>
                
                <Border Height="1" Background="{StaticResource BorderSubtleBrush}" />
                
                <!-- Auto-analyze -->
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Auto-analyze on load"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Automatically start AI analysis when files are loaded"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" 
                                IsChecked="{Binding AutoAnalyzeOnLoad}"
                                OnContent=""
                                OffContent="" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
          
          <!-- Appearance Section -->
          <StackPanel Spacing="12">
            <TextBlock Text="APPEARANCE"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Margin="0,0,0,4" />
            
            <Border Background="{StaticResource SurfaceElevatedBrush}"
                    CornerRadius="8"
                    Padding="16">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="Theme"
                             FontSize="13"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Text="Choose your preferred color scheme"
                             FontSize="11"
                             Foreground="{StaticResource TextTertiaryBrush}" />
                </StackPanel>
                <ComboBox Grid.Column="1"
                          Width="140"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding Theme}" />
              </Grid>
            </Border>
          </StackPanel>
          
        </StackPanel>
      </ScrollViewer>
      
      <!-- Footer Actions -->
      <Border Grid.Row="2"
              Background="{StaticResource SurfaceElevatedBrush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="0,1,0,0"
              Padding="24,16">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Grid.Column="0"
                  Theme="{StaticResource SubtleButton}"
                  Content="Reset to Defaults"
                  Command="{Binding ResetToDefaultsCommand}" />
          
          <StackPanel Grid.Column="2" 
                      Orientation="Horizontal" 
                      Spacing="8">
            <Button Theme="{StaticResource SecondaryButton}"
                    Content="Cancel"
                    Click="OnCancelClicked" />
            <Button Theme="{StaticResource PrimaryButton}"
                    Content="Save Changes"
                    Click="OnSaveClicked" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
