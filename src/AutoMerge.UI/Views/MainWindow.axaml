<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoMerge.UI.Views.Panels"
        xmlns:converters="clr-namespace:AutoMerge.UI.Converters"
        x:Class="AutoMerge.UI.Views.MainWindow"
        Width="1200" Height="800" Title="AutoMerge">
  <Window.Resources>
    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
  </Window.Resources>
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="2*,3*">
    <Border Padding="8" Grid.ColumnSpan="2">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Open Merge..." Click="OnOpenMergeClicked" />
        <Button Content="Analyze" Command="{Binding AnalyzeCommand}" ToolTip.Tip="{Binding AiStatusMessage}" />
        <Button Content="Get AI Help" Command="{Binding GetAiHelpCommand}" ToolTip.Tip="{Binding AiStatusMessage}" />
        <Button Content="Reconnect AI" Command="{Binding ReconnectAiCommand}" IsVisible="{Binding IsAiAvailable, Converter={StaticResource InverseBoolConverter}}" />
        <Button Content="Save Draft" Click="OnSaveDraftClicked" ToolTip.Tip="Cmd/Ctrl+S" />
        <Button Content="Preferences" Click="OnOpenPreferencesClicked" ToolTip.Tip="Cmd/Ctrl+," />
        <Button Content="Accept" Command="{Binding AcceptCommand}" ToolTip.Tip="Cmd/Ctrl+Enter" />
        <Button Content="Cancel" Command="{Binding CancelCommand}" ToolTip.Tip="Escape" />
        <Button Content="Retry Load" Command="{Binding RetryLoadCommand}" IsVisible="{Binding HasError}" />
        <TextBlock Text="{Binding State}" Margin="12,0,0,0" />
        <TextBlock Text="{Binding ErrorMessage}" Foreground="OrangeRed" Margin="12,0,0,0" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*" IsVisible="{Binding IsSessionLoaded}">
      <Grid RowDefinitions="*,*,*" Grid.Column="0">
        <views:DiffPaneView DataContext="{Binding BasePaneViewModel}" />
        <views:DiffPaneView Grid.Row="1" DataContext="{Binding LocalPaneViewModel}" />
        <views:DiffPaneView Grid.Row="2" DataContext="{Binding RemotePaneViewModel}" />
      </Grid>

      <Grid Grid.Column="1" RowDefinitions="3*,2*">
        <views:MergedResultView DataContext="{Binding MergedResultViewModel}" />
        <views:AiChatPanelView Grid.Row="1" DataContext="{Binding AiChatViewModel}" />
      </Grid>
    </Grid>

    <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="24"
            IsVisible="{Binding IsSessionLoaded, Converter={StaticResource InverseBoolConverter}}">
      <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
        <TextBlock Text="Open merge files to get started" FontSize="20" FontWeight="Bold" TextAlignment="Center" />
        <TextBlock Text="Select Local (ours), Remote (theirs), and Merged (output). Base is optional." TextWrapping="Wrap" TextAlignment="Center" />
        <Button Content="Open Merge..." HorizontalAlignment="Center" Click="OnOpenMergeClicked" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
