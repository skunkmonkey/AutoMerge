<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AutoMerge.UI.Controls"
             x:Class="AutoMerge.UI.Views.Panels.MergedResultView">
  
  <Border Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid RowDefinitions="Auto,*">
      
      <!-- Panel Header -->
      <Border Grid.Row="0"
              Background="#3A1E5F"
              CornerRadius="8,8,0,0"
              Padding="12,10">
        <Grid ColumnDefinitions="Auto,*,Auto">
          
          <!-- Icon + Title -->
          <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="0">
            <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center" />
            <StackPanel Spacing="2">
              <TextBlock Text="Merged Result" 
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         FontSize="14" />
              <TextBlock Text="Final resolved output (editable)"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="11"
                         Opacity="0.8" />
            </StackPanel>
          </StackPanel>
          
          <!-- Revert Buttons -->
          <StackPanel Grid.Column="2" 
                      Orientation="Horizontal" 
                      Spacing="6">
            
            <!-- Conflict Markers Warning -->
            <Border Background="#80F44336"
                    CornerRadius="4"
                    Padding="10,6"
                    IsVisible="{Binding HasConflictMarkers}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="⚠️" FontSize="12" />
                <TextBlock Text="Conflict markers detected"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"
                           FontWeight="Medium" />
              </StackPanel>
            </Border>
            
            <Button Theme="{StaticResource SubtleButton}"
                    Content="↩ Base" 
                    Command="{Binding RevertToBaseCommand}"
                    ToolTip.Tip="Revert to base version"
                    Padding="10,6"
                    FontSize="12" />
            
            <Button Theme="{StaticResource SubtleButton}"
                    Content="↩ Local" 
                    Command="{Binding RevertToLocalCommand}"
                    ToolTip.Tip="Revert to local (ours) version"
                    Padding="10,6"
                    FontSize="12" />
            
            <Button Theme="{StaticResource SubtleButton}"
                    Content="↩ Remote" 
                    Command="{Binding RevertToRemoteCommand}"
                    ToolTip.Tip="Revert to remote (theirs) version"
                    Padding="10,6"
                    FontSize="12" />
          </StackPanel>
        </Grid>
      </Border>
      
      <!-- Code Editor (Editable) -->
      <Border Grid.Row="1" 
              Background="#1A1A1E"
              CornerRadius="0,0,8,8"
              ClipToBounds="True">
        <controls:CodeEditorControl
            Text="{Binding Content, Mode=TwoWay}"
            IsReadOnly="False"
            SyntaxLanguage="{Binding SyntaxLanguage}"
            ShowConflictMarkers="True" />
      </Border>
    </Grid>
  </Border>
</UserControl>
